# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
# Direct connection (used by Prisma migrations; same as DATABASE_URL for non-pooled setups)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── Auth ──────────────────────────────────────────────────────────────────────
# At least 32-char random string — generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_MIN_32_CHARS"
# Token lifetime (e.g. "7d", "24h")
JWT_EXPIRES_IN="7d"

# ── Encryption ────────────────────────────────────────────────────────────────
# 64-char hex string (32 bytes) for AES-256-GCM API key encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_64_HEX_CHARS"

# ── LLM providers ─────────────────────────────────────────────────────────────
# Options: openai | claude | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Only needed when LLM_PROVIDER=claude
CLAUDE_API_KEY=
# Only needed when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
# Leave blank for local dev (falls back to in-memory limiter)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron ──────────────────────────────────────────────────────────────────────
# Secret checked by /api/cron/cleanup — set in Vercel dashboard and Vercel Cron config
CRON_SECRET="CHANGE_ME"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Deployment mode: "standalone" (self-hosted, full Puppeteer) or "hosted" (Vercel, @sparticuz/chromium)
DEPLOYMENT_MODE=standalone
# bcrypt work factor (default 12; increase for extra security, decrease for faster tests)
BCRYPT_ROUNDS=12
