{
  "name": "reportgenius",
  "version": "1.0.0",
  "description": "Self-hosted teacher report generation platform",
  "private": true,
  "scripts": {
    "db:generate": "prisma generate --schema=./frontend/prisma/schema.prisma",
    "db:push": "prisma db push --schema=./frontend/prisma/schema.prisma",
    "db:seed": "ts-node --project tsconfig.seed.json frontend/prisma/seed.ts",
    "db:studio": "prisma studio --schema=./frontend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./frontend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "puppeteer-core": "^24.40.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json frontend/prisma/seed.ts"
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
