{
  "name": "reportgenius-backend",
  "version": "1.0.0",
  "description": "ReportGenius Express API",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=../.env dist/server.js",
